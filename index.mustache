---
{
    "title": "Josemi Juanes | React Developer and Minimal Design Lover",
    "layout": "default.mustache",
    "permalink": "/index.html"
}
---
{{>>josemi:container size="7xl"}}
    {{>josemi:hero
        heading="Hey, I'm Josemi."
        description="I'm a passionate <b>mathematician</b> turned <b>React</b> developer that loves to craft minimal, beautiful, and performant user interfaces."
        actions=site.data.socials
    }}
    {{>>josemi:section}}
        {{>josemi:section-intro heading="Projects"}}
        <div class="flex flex-col gap-6 mb-6">
        {{#each site.data.projects limit=4}}
            {{>josemi:pillar
                heading=this.title
                description=this.description
                label=this.date
                url=this.url
            }}
        {{/each}}
        </div>
        <div class="">
            <a class="inline-flex items-center gap-1 lh-none no-underline hover:underline" href="/projects.html">
                <span class="text-lg">See all projects</span>
                {{>josemi:icon icon="arrow-right"}}
            </a>
        </div>
    {{/josemi:section}}
    {{>>josemi:section}}
        {{>josemi:section-intro heading="Notes"}}
        <div class="flex flex-col gap-6 mb-6">
        {{#pages collection="notes" limit=4}}
            {{>josemi:pillar
                heading=this.attributes.title
                description=this.attributes.description
                label=this.attributes.date
                url=this.url
            }}
        {{/pages}}
        </div>
        <div class="">
            <a class="inline-flex items-center gap-1 lh-none no-underline hover:underline" href="/notes.html">
                <span class="text-lg">See all notes</span>
                {{>josemi:icon icon="arrow-right"}}
            </a>
        </div>
    {{/josemi:section}}
{{/josemi:container}}
{{>footer.mustache links=site.data.socials}}
